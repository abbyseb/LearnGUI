#ifndef __igtConfiguration_h
#define __igtConfiguration_h
//This file is interpreted by cmake, to define macros based on the cmake configuration options
//

#include <itkConfigure.h>
#include <itkIntTypes.h>
namespace igt
{
  typedef itk::ThreadIdType ThreadIdType;
}

#ifndef CUDA_FOUND
#cmakedefine CUDA_FOUND
#endif
#ifndef OPENCL_FOUND
#cmakedefine OPENCL_FOUND
#endif
#cmakedefine IGT_USE_CUDA
#cmakedefine IGT_USE_OPENCL
#cmakedefine IGT_BUILD_SHARED_LIBS 1

#define IGT_BINARY_DIR "@IGT_BINARY_DIR@"

#ifndef SLAB_SIZE
  #define SLAB_SIZE @IGT_CUDA_PROJECTIONS_SLAB_SIZE@
#endif

/* Fix for ITK4 */
#if defined(ITK_USE_FFTWF) && !defined(USE_FFTWF)
#  define USE_FFTWF
#endif
#if defined(ITK_USE_FFTWD) && !defined(USE_FFTWD)
#  define USE_FFTWD
#endif

#endif
