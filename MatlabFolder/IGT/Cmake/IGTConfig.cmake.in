SET(IGT_INCLUDE_DIRS "@IGT_INCLUDE_DIRS@")
SET(IGT_LIBRARY_DIRS "@IGT_LIBRARY_DIRS@")
SET(IGT_LIBRARIES "@IGT_LIBRARIES@")

# The RTK version number
SET(IGT_VERSION_MAJOR "@IGT_VERSION_MAJOR@")
SET(IGT_VERSION_MINOR "@IGT_VERSION_MINOR@")
SET(IGT_VERSION_PATCH "@IGT_VERSION_PATCH@")

# The location of the UseIGT.cmake file.
SET(IGT_USE_FILE "@IGT_USE_FILE@")

# Whether the compiled version of RTK uses CUDA
SET(IGT_USE_CUDA @IGT_USE_CUDA@)

